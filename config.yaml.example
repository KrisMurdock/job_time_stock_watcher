# ===========================================================================
# Stock Watcher 配置文件
# ===========================================================================
# 修改此文件后无需重启程序 — 自动检测并热加载，或按 Ctrl+N 手动触发。
#
# 代码前缀说明：
#   sh = 上海A股 (例: sh600519 = 贵州茅台)
#   sz = 深圳A股 (例: sz000001 = 平安银行)
#   hk = 港股    (例: hk00700 = 腾讯控股)
#   us = 美股    (例: usaapl = 苹果)
# ===========================================================================

# ---------------------------------------------------------------------------
# 轮询间隔（秒）
# 控制每隔多少秒拉取一次最新行情。A股交易时段内持续轮询，
# 休市时段自动暂停以节省带宽。
# ---------------------------------------------------------------------------
poll_interval: 2.5

# ---------------------------------------------------------------------------
# 自选股列表
# 在 TUI 中按 a 键添加股票，按 d 键删除。
# ---------------------------------------------------------------------------
watchlist:
- sh603848
- sz002920
- sz002278
- sh600678
- sz000785
- sz000537
- sh600032
- sh600905
- hk00700
- ustsla
- usgoog
- usbaba

# ---------------------------------------------------------------------------
# 告警规则
# 当股价或涨跌幅触发设定条件时，TUI 底部会弹出通知。
# 每条规则包含三个字段：
#   code  - 股票代码（带前缀）
#   type  - 告警类型：price_above | price_below | pct_above | pct_below
#   value - 阈值（价格用元，百分比用数字，如 5.0 表示 5%）
# ---------------------------------------------------------------------------
alerts:
# 示例：当贵州茅台股价上破 1800 元时触发告警（取消注释即可启用）
# - code: sh600519
#   type: price_above / price_below
#   value: 1800.0
- code: hk00700
  type: price_above
  value: 433.0

# ---------------------------------------------------------------------------
# 代理设置
# 如需通过 HTTP 代理访问行情接口，在此添加代理地址。
# 留空表示直连。
# 示例: ["http://127.0.0.1:7890", "http://user:pass@proxy:8080"]
# ---------------------------------------------------------------------------
proxies: []

# ---------------------------------------------------------------------------
# HTTP 请求配置
# ---------------------------------------------------------------------------
request:
  # 请求超时（秒）
  timeout: 10
  # User-Agent 池 — 每次请求随机选一个，降低被反爬的概率
  user_agent_pool:
  - Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko)
    Chrome/126.0.0.0 Safari/537.36
  - Mozilla/5.0 (Macintosh; Intel Mac OS X 14_5) AppleWebKit/605.1.15 (KHTML, like
    Gecko) Version/17.4 Safari/605.1.15
  - Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/126.0.0.0
    Safari/537.36

# ---------------------------------------------------------------------------
# 失败重试策略（指数退避）
# 当 API 请求失败时，按照 基数 × 乘数^次数 的公式延迟重试，
# 但最长不超过 max 秒。每次延迟随机浮动 ±25% 以避免惊群效应。
# ---------------------------------------------------------------------------
backoff:
  # 初始退避秒数
  base: 5
  # 最大退避秒数（天花板）
  max: 120
  # 每次失败的退避乘数
  multiplier: 2

# ---------------------------------------------------------------------------
# 告警声音
# 触发告警时终端会响铃（\a）。如需播放自定义音效，在此填入 shell 命令。
# 命令以非阻塞方式执行，不影响主程序运行。
#
# Linux 示例: "paplay /usr/share/sounds/freedesktop/stereo/alarm-clock-elapsed.oga"
# macOS 示例: "afplay /System/Library/Sounds/Ping.aiff"
# Windows 示例: "powershell -c (New-Object Media.SoundPlayer 'C:\\Windows\\Media\\Alarm01.wav').PlaySync()"
#
# 留空表示仅使用终端响铃。
# ---------------------------------------------------------------------------
alert_sound_command: ""

# ---------------------------------------------------------------------------
# 飞书/钉钉机器人通知
# 在群设置中添加自定义机器人，将 webhook URL 填到下方。
# feishu_secret 是签名密钥（可选，在机器人设置页面获取）。
# ---------------------------------------------------------------------------
chat:
  feishu_webhook: "https://open.feishu.cn/open-apis/bot/v2/hook/YOUR-WEBHOOK-URL"
  feishu_secret: ""
  # 机器人双向对话需要：在飞书开放平台创建「企业自建应用」获取
  feishu_app_id: "YOUR-APP-ID"
  feishu_app_secret: "YOUR-APP-SECRET"

# ---------------------------------------------------------------------------
# DeepSeek AI 对话（用于群内 @机器人 智能回复）
# api_key 在 https://platform.deepseek.com/api_keys 获取
# ---------------------------------------------------------------------------
deepseek:
  api_key: "YOUR-API-KEY"
  model: "deepseek-chat"

# ---------------------------------------------------------------------------
